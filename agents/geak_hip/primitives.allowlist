# CDNA4 (gfx950) primitives that MUST appear in any generated kernel's
# llvm-objdump output. The audit (kernel_audit.sh) greps for at least
# one match in each REQUIRED block. Without these the kernel is
# falling back to scalar / generic paths and won't beat AITER.
#
# The audit also fails CLOSED if forbidden.tokens matches.

# ===== REQUIRED =====
# Scaled MFMA — the headline CDNA4 instruction; any FP4/FP8 GEMM that
# doesn't use scaled MFMA is leaving 8-16x peak on the floor.
v_mfma_scale_f32_16x16x128_f8f6f4
v_mfma_scale_f32_32x32x64_f8f6f4

# Direct-to-LDS load — the CDNA4 ds_read with byte-shuffle that lets
# us avoid the VGPR round-trip for FP4-packed loads.
ds_read_b64_tr_b4

# Atomic packed BF16 add — required for any reduce-scatter style epilogue.
global_atomic_pk_add_bf16

# Scheduler hint — required for waves_per_eu>=3 + s_setprio interleave.
sched_group_barrier

# OPTIONAL but strongly desirable (audit warns if missing, doesn't fail):
# - s_setprio  (priority swap to overlap MFMA with mem)
# - ds_swizzle (XOR LDS swizzle for bank-conflict-free swizzled load)
